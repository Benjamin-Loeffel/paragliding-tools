<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Adelboden–Frutigen–Niesen wide (~39x39 km) — flight-day briefing domain</name>
    <!-- Grosszügige Domäne fürs tägliche Thermik-Briefing, deckt Benjamins Startgebiete ab:
         Tschentenalp/Adelboden (46.50N/7.55E, inkl. Engstligen-Seite im Süden),
         Frutigen mit Trutten/Grimer (46.57N/7.63E), Niesen (46.65N/7.65E).
         Fuer den Morgenlauf mit groeberer resolution_m (50-100 m) verwenden. -->
    <Placemark>
      <name>briefing domain</name>
      <Polygon>
        <outerBoundaryIs>
          <LinearRing>
            <coordinates>
              7.400,46.400 7.840,46.400 7.840,46.750 7.400,46.750 7.400,46.400
            </coordinates>
          </LinearRing>
        </outerBoundaryIs>
      </Polygon>
    </Placemark>
  </Document>
</kml>
