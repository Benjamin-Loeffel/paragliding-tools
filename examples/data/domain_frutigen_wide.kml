<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Frutigen wide (~30x30 km) — flight-day briefing domain</name>
    <!-- Rechteck um Niesen/Frutigen, ~+10 km je Richtung ggü. der feinen Domäne, damit
         das Thermik-/Windmodell den grossraeumigen Gelaendeeinfluss (Taeler, Luv/Lee) sieht.
         Fuer den Morgenlauf mit groeberer resolution_m (50-100 m) verwenden. -->
    <Placemark>
      <name>briefing domain</name>
      <Polygon>
        <outerBoundaryIs>
          <LinearRing>
            <coordinates>
              7.405,46.455 7.835,46.455 7.835,46.745 7.405,46.745 7.405,46.455
            </coordinates>
          </LinearRing>
        </outerBoundaryIs>
      </Polygon>
    </Placemark>
  </Document>
</kml>
